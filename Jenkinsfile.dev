pipeline {
    agent any

    parameters {
        booleanParam(name: 'NO_CACHE', defaultValue: false, description: 'Docker build cache kullanma')
        booleanParam(name: 'DEPLOY_TO_DEV', defaultValue: true, description: 'Build sonrasi DEV ortamina otomatik deploy yap')
    }

    environment {
        REGISTRY = 'docker.io'
        IMAGE_NAME = 'mstfaock/livestocktrading-web'
        TAG_SUFFIX = 'dev-latest'
        IMMUTABLE_TAG = "dev-${BUILD_ID}-${GIT_COMMIT.take(8)}"
        DOCKER_BUILDKIT = '1'

        DOCKERHUB_CREDENTIAL_ID = 'dockerhub-credentials'
        SERVER_SSH_KEY_ID = 'maden-server-key'
        SERVER_HOST_ID = 'dev-server-host'

        // NEXT_PUBLIC env vars (client-side, not secrets)
        NEXT_PUBLIC_GOOGLE_CLIENT_ID = '125129858406-3f2dshkik7m37ch5am3v9rtv5p47ad8i.apps.googleusercontent.com'
        NEXT_PUBLIC_GOOGLE_PLACES_API_KEY = 'AIzaSyCAth2kFsXa9W9uQTftAVpJ9fFaBi76KG0'
        NEXT_PUBLIC_DEFAULT_COMPANY_ID = '9dae9cbd-82b1-4ead-bd2b-9c5fe5146a2a'
        NEXT_PUBLIC_SENTRY_DSN = 'https://d6270f5fc5245a74c8c8748626a15f64@o4511000000462848.ingest.de.sentry.io/4511000004001872'

        CONTAINER_NAME = 'livestock_dev_web'
        HOST_PORT = '3099'
        CONTAINER_PORT = '3000'
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '20'))
        timeout(time: 1, unit: 'HOURS')
        timestamps()
    }

    stages {
        stage('Checkout') {
            steps {
                script {
                    echo "DEV WEB: Kod cekiliyor..."
                    sh '''
                        echo "Kod basariyla cekildi"
                        echo "Branch: ${GIT_BRANCH}"
                        echo "Commit: ${GIT_COMMIT}"
                    '''
                }
            }
        }

        stage('Docker Login') {
            steps {
                script {
                    withCredentials([usernamePassword(
                        credentialsId: env.DOCKERHUB_CREDENTIAL_ID,
                        usernameVariable: 'DOCKER_USERNAME',
                        passwordVariable: 'DOCKER_PASSWORD'
                    )]) {
                        sh '''
                            echo "$DOCKER_PASSWORD" | docker login -u "$DOCKER_USERNAME" --password-stdin > /dev/null 2>&1 && \
                            echo "Docker Hub login basarili (DEV WEB)" || \
                            (echo "Docker login basarisiz!"; exit 1)
                        '''
                    }
                }
            }
        }

        stage('Build & Push Image') {
            steps {
                script {
                    echo "DEV WEB: Docker image build ediliyor..."

                    def cacheArgs = params.NO_CACHE ? '--no-cache' : ''

                    timeout(time: 30, unit: 'MINUTES') {
                        sh """
                            docker buildx build \
                                ${cacheArgs} \
                                --file Dockerfile \
                                --build-arg NEXT_PUBLIC_ENVIRONMENT=development \
                                --build-arg NEXT_PUBLIC_GOOGLE_CLIENT_ID=${NEXT_PUBLIC_GOOGLE_CLIENT_ID} \
                                --build-arg NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=${NEXT_PUBLIC_GOOGLE_PLACES_API_KEY} \
                                --build-arg NEXT_PUBLIC_DEFAULT_COMPANY_ID=${NEXT_PUBLIC_DEFAULT_COMPANY_ID} \
                                --build-arg "NEXT_PUBLIC_SENTRY_DSN=${NEXT_PUBLIC_SENTRY_DSN}" \
                                --tag ${IMAGE_NAME}:${TAG_SUFFIX} \
                                --tag ${IMAGE_NAME}:${IMMUTABLE_TAG} \
                                --label org.opencontainers.image.revision=${GIT_COMMIT} \
                                --label org.opencontainers.image.version=${IMMUTABLE_TAG} \
                                --provenance=false \
                                --sbom=false \
                                --pull \
                                --push .
                        """
                    }

                    echo "DEV WEB: Image basariyla build edildi ve push edildi"
                    sh 'docker image prune -f || true'
                }
            }
        }

        stage('Deploy to DEV') {
            when {
                allOf {
                    expression {
                        env.GIT_BRANCH == 'dev' ||
                        env.GIT_BRANCH == 'origin/dev' ||
                        env.GIT_BRANCH.endsWith('/dev')
                    }
                    expression { params.DEPLOY_TO_DEV == true }
                }
            }
            steps {
                script {
                    echo "DEV WEB: Sunucuya deploy basliyor..."

                    withCredentials([
                        sshUserPrivateKey(credentialsId: env.SERVER_SSH_KEY_ID, keyFileVariable: 'SSH_KEY', usernameVariable: 'SSH_USER'),
                        string(credentialsId: env.SERVER_HOST_ID, variable: 'SERVER_HOST'),
                        usernamePassword(credentialsId: env.DOCKERHUB_CREDENTIAL_ID, usernameVariable: 'DOCKER_USERNAME', passwordVariable: 'DOCKER_PASSWORD')
                    ]) {
                        def sshUser = SSH_USER
                        def sshHost = SERVER_HOST
                        def dockerUser = DOCKER_USERNAME
                        def dockerPass = DOCKER_PASSWORD

                        sh """
                            chmod 600 "\$SSH_KEY"

                            ssh -o StrictHostKeyChecking=no -i "\$SSH_KEY" ${sshUser}@${sshHost} bash <<'ENDSSH'
export DOCKER_USERNAME='${dockerUser}'
export DOCKER_PASSWORD='${dockerPass}'

set -e

echo "Docker Hub login yapiliyor..."
echo "\$DOCKER_PASSWORD" | docker login -u "\$DOCKER_USERNAME" --password-stdin || {
    echo "Docker Hub login basarisiz!";
    exit 1;
}

IMAGE="${IMAGE_NAME}:${TAG_SUFFIX}"
COMPOSE_DIR="/opt/livestocktrading/repo/_devops/docker/compose"
ENV_FILE="/opt/livestocktrading/.env.dev"

echo "Yeni image cekiliyor: \$IMAGE"
docker pull \$IMAGE

# Eski manual container varsa kaldir (migration)
docker stop ${CONTAINER_NAME} 2>/dev/null || true
docker rm ${CONTAINER_NAME} 2>/dev/null || true

echo "Docker Compose ile web servisi yeniden baslatiliyor..."
cd \$COMPOSE_DIR
docker compose -p livestock_dev \
    -f docker-compose.yml \
    -f docker-compose.dev.yml \
    --env-file \$ENV_FILE \
    up -d --force-recreate web

echo "Container baslatildi, saglik kontrolu yapiliyor..."
sleep 5

if docker compose -p livestock_dev ps web --format json | grep -q '"running"'; then
    echo "DEV WEB deploy basariyla tamamlandi!"
    echo "Erisim: http://\$(hostname -I | awk '{print \$1}'):${HOST_PORT}"
else
    echo "Container baslatma basarisiz!"
    docker compose -p livestock_dev logs web --tail=50
    exit 1
fi

echo "Eski Docker imajlari temizleniyor..."
docker image prune -f
ENDSSH
                        """
                    }
                }
            }
        }

        stage('Cleanup') {
            steps {
                script {
                    echo "Jenkins build artifacts temizleniyor..."
                    sh '''
                        docker image prune -f || true
                        docker builder prune -f --filter type=exec.cachemount || true
                    '''
                }
            }
        }
    }

    post {
        success {
            echo "DEV WEB Pipeline basariyla tamamlandi!"
            echo "Build ID: ${BUILD_ID}"
            echo "Commit: ${GIT_COMMIT}"
            echo "Tag: ${IMMUTABLE_TAG}"
            echo "Image: ${IMAGE_NAME}:${TAG_SUFFIX}"
        }
        failure {
            echo "DEV WEB Pipeline basarisiz oldu!"
            echo "Build ID: ${BUILD_ID}"
            echo "Commit: ${GIT_COMMIT}"
        }
        always {
            sh 'docker logout || true'
        }
    }
}
