{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "baseUrl": "./src",
    "paths": {
      "@config/*": ["./config/*"],
      "@services/*": ["./services/*"],
      "@errors/*": ["./errors/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
